{
  "name": "cirtell-api",
  "version": "1.0.0",
  "description": "Cirtell API - Cloudflare Workers with D1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create cirtell-db",
    "db:migrate:local": "wrangler d1 migrations apply cirtell-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cirtell-db --remote",
    "db:seed:demo:local": "wrangler d1 execute cirtell-db --local --file ./seeds/cirtell_demo_dataset.sql",
    "db:seed:demo:remote": "wrangler d1 execute cirtell-db --remote --file ./seeds/cirtell_demo_dataset.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260103.0",
    "typescript": "^5.4.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.76.0"
  }
}
