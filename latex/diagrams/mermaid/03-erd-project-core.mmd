erDiagram
  PROJECTS ||--o{ PROJECT_EQUIPMENT : tracks
  PROJECTS ||--o{ PROJECT_WORKFLOW_STAGES : has_stages
  PROJECT_WORKFLOW_STAGES ||--o{ PROJECT_WORKFLOW_TASKS : has_tasks
  PROJECTS ||--o{ PROJECT_FINANCIALS : records
  WAREHOUSES ||--o{ PROJECTS : source
