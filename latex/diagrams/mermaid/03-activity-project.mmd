flowchart TD
  Start([Start]) --> Auth["Xác thực người dùng"]
  Auth --> Perm["Kiểm tra MANAGE_PROJECTS"]
  Perm --> Scope["Resolve tenant/company scope"]
  Scope --> Header["Nhập project header"]
  Header --> Valid{"Dữ liệu và scope hợp lệ?"}

  Valid -->|No| Error["Trả lỗi 400/403/404"]
  Error --> End([End])

  Valid -->|Yes| WriteProject["Ghi projects"]
  WriteProject --> Stages["Tạo workflow stages mặc định"]
  Stages --> HasTabs{"Có dữ liệu kèm theo?"}

  HasTabs -->|Yes| WriteTabs["Ghi equipment/logistics/financials/evidence"]
  HasTabs -->|No| SkipTabs["Bỏ qua dữ liệu tab"]

  WriteTabs --> Activity["Ghi project_activity"]
  SkipTabs --> Activity
  Activity --> Audit["Ghi audit log"]
  Audit --> End

  classDef startEnd fill:#e6f7ef,stroke:#047857,stroke-width:2px,color:#064e3b;
  classDef process fill:#f8fafc,stroke:#64748b,stroke-width:1px,color:#0f172a;
  classDef decision fill:#fff7ed,stroke:#c2410c,stroke-width:1px,color:#7c2d12;
  classDef error fill:#fef2f2,stroke:#dc2626,stroke-width:1px,color:#7f1d1d;
  classDef data fill:#ecfdf5,stroke:#059669,stroke-width:1px,color:#064e3b;
  classDef audit fill:#f0fdf4,stroke:#16a34a,stroke-dasharray: 4 3,color:#14532d;

  class Start,End startEnd;
  class Auth,Perm,Scope,Header,Stages,SkipTabs process;
  class Valid,HasTabs decision;
  class Error error;
  class WriteProject,WriteTabs data;
  class Activity,Audit audit;
